<?xml version="1.0" encoding="UTF-8"?>
<!--
  Task Scheduler definition for the Fallow per-machine agent (Windows).

  WHY A SCHEDULED TASK IN THE USER SESSION, NOT A WINDOWS SERVICE:
  Fallow's idle detection calls GetLastInputInfo (user32), which returns the
  time of the last keyboard/mouse input for the CURRENTLY ACTIVE user session.
  A Windows Service runs in session 0 (the isolated service session) and has no
  interactive input desk, so GetLastInputInfo returns useless data and Fallow
  would never yield to the user. Therefore the agent MUST run as an at-logon
  Scheduled Task with LogonType=InteractiveToken and RunLevel=LeastPrivilege in
  the user's own session.

  install.ps1 templates the __TOKENS__ below (registered user + venv pythonw +
  config path + working dir) and registers the result. Do not import this file
  directly.
-->
<Task version="1.4" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Fallow opportunistic AI compute agent (runs in the user session for idle detection).</Description>
    <URI>\Fallow\FallowAgent</URI>
  </RegistrationInfo>
  <Triggers>
    <LogonTrigger>
      <Enabled>true</Enabled>
      <UserId>__USERID__</UserId>
    </LogonTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <UserId>__USERID__</UserId>
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>false</RunOnlyIfNetworkAvailable>
    <IdleSettings>
      <StopOnIdleEnd>false</StopOnIdleEnd>
      <RestartOnIdle>false</RestartOnIdle>
    </IdleSettings>
    <AllowStartOnDemand>true</AllowStartOnDemand>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <RunOnlyIfIdle>false</RunOnlyIfIdle>
    <DisallowStartOnRemoteAppSession>false</DisallowStartOnRemoteAppSession>
    <UseUnifiedSchedulingEngine>true</UseUnifiedSchedulingEngine>
    <WakeToRun>false</WakeToRun>
    <ExecutionTimeLimit>PT0S</ExecutionTimeLimit>
    <Priority>7</Priority>
    <!-- Restart-on-failure: keep the agent alive across crashes/preemption. -->
    <RestartOnFailure>
      <Interval>PT1M</Interval>
      <Count>999</Count>
    </RestartOnFailure>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <!-- pythonw.exe: no console window in the user's session. -->
      <Command>__PYTHONW__</Command>
      <Arguments>-m fallow_agent run --config "__CONFIG__"</Arguments>
      <WorkingDirectory>__WORKDIR__</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
